{
  "private": true,
  "scripts": {
    "css:build": "npx @tailwindcss/cli -i src/web/static/input.css -o src/web/static/styles.css --minify",
    "css:watch": "npx @tailwindcss/cli -i src/web/static/input.css -o src/web/static/styles.css --watch",
    "format:text": "prettier --write .",
    "format:text:check": "prettier --check .",
    "format:toml": "taplo format pyproject.toml",
    "format:toml:check": "taplo format --check pyproject.toml",
    "lint:toml": "taplo lint pyproject.toml"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@taplo/cli": "^0.7.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ini": "^1.3.0",
    "prettier-plugin-packagejson": "^3.0.2"
  }
}
