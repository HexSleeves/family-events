# === Secrets & Infrastructure ===
# User preferences (notification channels, email recipient, child name,
# interest profile, cities) are stored in the user's DB profile.

# Required
OPENAI_API_KEY=sk-...

# Weather (OpenWeatherMap)
WEATHER_API_KEY=

# SMS (Twilio) — sender credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Telegram — bot credentials
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email (Resend) — sender identity
RESEND_API_KEY=
EMAIL_FROM=Family Events <onboarding@resend.dev>

# Session cookie signing key (required in production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=
# Public HTTPS origin for same-origin checks when behind a proxy, e.g. https://noon-disk.exe.xyz:8000
APP_BASE_URL=
# Session cookie hardening
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_DOMAIN=
SESSION_MAX_AGE_SECONDS=2592000

# Basic API rate limiting (per-IP per-route)
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
AUTH_RATE_LIMIT_MAX_REQUESTS=10
